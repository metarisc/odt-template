{
    "name": "metarisc-odt/odt-template",

    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/loupmyr/odt-template"
        }
    ],

    "autoload": {
        "psr-4": {
            "Metarisc\\OdtParser\\": "src/"
        }
    },

    "require": {
        "metarisc-odt/lexical-parser": "*",
        "loupmyr/odt": "*",
        "beberlei/assert": "^3.3"
    },

    "require-dev": {
        "kdubuc/php-cs-fixer-rules": "^1.0",
        "vimeo/psalm": "^4.23"
    },

    "scripts": {
        "fix-cs": "php vendor/bin/php-cs-fixer fix --config=vendor/kdubuc/php-cs-fixer-rules/php-cs-fixer.php",
        "analyze": "php vendor/bin/psalm --no-cache"
    },

    "minimum-stability": "dev",
    "prefer-stable": true
}
